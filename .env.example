# ================================================
# APHRNTs_100 — Misskey AI Bot 環境変数テンプレート
# ================================================
# このファイルをコピーして .env にリネームし、各値を設定してください。
# .env は .gitignore で管理対象外にしてあります。絶対にコミットしないこと。

# ------------------------------------------------
# Misskey 接続設定
# ------------------------------------------------
# BotアカウントのMisskeyインスタンスURL（末尾スラッシュなし）
MISSKEY_HOST=

# BotアカウントのAPIアクセストークン
# Misskeyの「設定 > APIトークン」から発行してください
MISSKEY_TOKEN=

# Misskeyストリームのkeepalive用ping送信間隔（ミリ秒・省略可・既定30秒）。
# アイドル時にサーバ/LBのWebSocketアイドルタイムアウトで切断されるのを防ぐため、
# その値より十分短くする。切断時は指数バックオフ＋ジッタで自動再接続する
# （設計の詳細は deploy/README.md「Misskeyストリームの接続維持」を参照）。
MISSKEY_PING_INTERVAL_MS=30000

# 取りこぼし回収（replay）の定期実行間隔（ミリ秒・省略可・既定60秒）。
# keepaliveで接続が安定して再接続が起きなくなると、replayが接続イベント起点でしか走らず、
# ライブのメンション/一対一チャットを取りこぼすと拾い直せなくなる。これを防ぐため、接続の
# 有無に依らずこの間隔でREST APIから未処理分を回収する（一対一チャットのライブ受信が未達でも
# この間隔内で応答できる）。短くするほど応答は速いがAPI呼び出しが増える。
REPLAY_INTERVAL_MS=60000

# ------------------------------------------------
# AI API設定
# ------------------------------------------------
# 使用するAIプロバイダー（anthropic / openai / gemini）
# センパイの意向により、Claude(anthropic)をデフォルトの主エンジンとする
AI_PROVIDER=anthropic

# Anthropic (Claude) APIキー（AI_PROVIDER=anthropic 時に使用・デフォルト）
ANTHROPIC_API_KEY=

# 使用するClaudeモデル（省略可・デフォルトはコード側の定数 claude-sonnet-5）
ANTHROPIC_MODEL=

# OpenAI APIキー（AI_PROVIDER=openai 時に使用）
OPENAI_API_KEY=

# 使用するOpenAIモデル（省略可）
OPENAI_MODEL=

# Google Gemini APIキー（AI_PROVIDER=gemini 時に使用）
GEMINI_API_KEY=

# 使用するGeminiモデル（省略可）
GEMINI_MODEL=

# ------------------------------------------------
# ストレージ設定
# ------------------------------------------------
# SQLiteデータベースのファイルパス（相対パス可）
DB_PATH=.cache/session.db

# ハートビートファイルの出力先（省略可・今回のスコープでは配線しない）
HEARTBEAT_PATH=.cache/heartbeat.json

# ハートビート書き込み間隔ミリ秒（省略可・デフォルト30秒）
HEARTBEAT_INTERVAL_MS=30000

# ------------------------------------------------
# Bot動作設定
# ------------------------------------------------
# 実行環境（development / production）
NODE_ENV=development

# ログレベル（error / warn / info / debug）
LOG_LEVEL=info

# ------------------------------------------------
# レートリミット設定（ミリ秒）
# ------------------------------------------------
# 同一ユーザーへのリプライのクールダウン（デフォルト: 30分）
RATE_LIMIT_REPLY_COOLDOWN_MS=1800000

# 1時間あたりの全体投稿数上限（安全弁）
RATE_LIMIT_GLOBAL_PER_HOUR=30

# ------------------------------------------------
# Claude連携ブリッジ設定（logs/ ⇄ SQLite）
# ------------------------------------------------
# 連携ブリッジの有効/無効（true / false）
CLAUDE_SYNC_ENABLED=true

# Claude(Desktop等)のセッション記録が置かれるディレクトリ
CLAUDE_LOGS_DIR=logs

# Bot記録ダイジェスト（Claudeが読む側）の出力先
BOT_DIGEST_PATH=logs/bot-digest.md

# ダイジェストに含める日数（既定14日）。月次振り返りなど一時的に長い期間が
# 必要な場合は、この値を変えずに `npm run sync:export -- --days=31` を使う。
BOT_DIGEST_DAYS=14

# Bot管理者（このリポジトリの所有者）のMisskeyユーザーID（例: 9abcdef123）
# 複数ユーザーにBotを開放する場合は必ず設定すること。設定すると、
#   - logs/bot-digest.md には管理者自身の記録だけが出力される
#   - logs/YYYY-MM-DD.md（Claudeセッション記録）は管理者との会話にのみ注入される
#   - 服薬の逆マージ（下記）と夜の服薬リマインドの対象が管理者に限定される
# 空の場合は単一ユーザー運用とみなし、全記録を対象にする。
# ※ 服薬の逆マージ（sync:import 時にセッション記録の「## 服薬」チェック済みスロットを
#    Botの服薬記録へ反映する機能）は、このIDが設定されている場合のみ動作する。
BOT_OWNER_USER_ID=

# ------------------------------------------------
# 本番VMとの相互同期の設定（npm run sync:remote / sync:push-remote / sync:pull-remote）
# ------------------------------------------------
# 本番Bot（GCE VM）はGitHubへの書き戻し経路を持たず、logs/ もgit管理外のため、
# ローカルとVMの間はどちらの方向にも自動では同期されない。
#   sync:pull-remote … gcloud compute ssh 経由でVM上の bot-digest.md を取得する
#   sync:push-remote … gcloud compute scp 経由でローカルの logs/*.md をVMへ転送し、VM上で取り込む
#   sync:remote      … 上記を両方向まとめて実行する
# （実行にはこのPCへのgcloud CLIインストール・認証と、VMへのSSH+sudo権限が必要）。
# 既定値は deploy/README.md 記載の本番VM構成に合わせてあるため、VMを再構築しない限り変更不要。
GCE_PROJECT=numbertales-misskey-surver
GCE_ZONE=asia-northeast1-a
GCE_INSTANCE=aphrnts-100-bot

# VM上の bot-digest.md の絶対パス。push側はここからVM上のログディレクトリ
# （/opt/aphrnts-100/logs）とリポジトリのルート（/opt/aphrnts-100）を導出するため、
# VMのパス設定はこの1項目に集約している。
REMOTE_BOT_DIGEST_PATH=/opt/aphrnts-100/logs/bot-digest.md

# VM上でBotを実行しているユーザー（deploy/README.md参照）。転送したログの所有者、
# およびVM上での sync:import / sync:export の実行ユーザーとして使う。
REMOTE_BOT_USER=aphrnts-bot

# gcloud CLIの実行ファイルパス（省略可）。
# 通常はPATH上のgcloud、またはWindowsの既定インストール先から自動解決するため空でよい。
GCLOUD_PATH=

# ------------------------------------------------
# 週次振り返り設定
# ------------------------------------------------
# 週次振り返りを提案する曜日（0=日曜〜6=土曜）
WEEKLY_SUMMARY_DAY_OF_WEEK=0

# 週次振り返りを提案する時刻（0〜23時）
WEEKLY_SUMMARY_HOUR=20

# ------------------------------------------------
# 日次振り返りリマインド設定
# ------------------------------------------------
# 毎日の振り返りリマインドをMisskeyへ送る時刻（0〜23時）
DAILY_REFLECTION_HOUR=20

# ------------------------------------------------
# 夜の服薬リマインド設定
# ------------------------------------------------
# 夜🌙の服薬リマインドを送る時刻（0〜23時）。その日の夜の服薬が「服用済み」で記録されていれば送らない。
# BOT_OWNER_USER_ID 設定時はオーナーへの一対一チャットのみ。
MED_REMINDER_HOUR=18
