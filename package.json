{
  "name": "aphrnts-100",
  "version": "0.1.0",
  "description": "「100(モモ)」のCBTセルフケア機能 コアエンジン + Misskey AI Bot（コア機能版）",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:cli": "tsx src/dev-cli/index.ts",
    "sync": "tsx src/bridge/cli.ts sync",
    "sync:import": "tsx src/bridge/cli.ts import",
    "sync:export": "tsx src/bridge/cli.ts export",
    "sync:pull-remote": "tsx src/bridge/cli.ts pull-remote",
    "sync:push-remote": "tsx src/bridge/cli.ts push-remote",
    "sync:remote": "tsx src/bridge/cli.ts sync-remote",
    "export:pdf": "node scripts/export-logs-pdf.mjs",
    "export:weekly-pdf": "node scripts/export-weekly-pdf.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google/generative-ai": "^0.24.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "misskey-js": "^2025.2.0",
    "openai": "^6.45.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
